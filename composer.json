{
    "name": "qpay-sdk/qpay-php",
    "description": "QPay V2 API PHP SDK with auto token management",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "QPay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "QPay\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "QPay PHP SDK Authors"
        }
    ],
    "minimum-stability": "stable",
    "scripts": {
        "test": "phpunit"
    }
}
